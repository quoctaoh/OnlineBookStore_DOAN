@model List<OnlineBookStore_Web.Models.ChiTietGioHang>

@{
    ViewData["Title"] = "Giỏ Hàng Của Tôi";
    // Biến để tính tổng tiền
    decimal total = 0;
}

<h1>Giỏ Hàng Của Tôi</h1>
<hr />

@* Hiển thị thông báo thành công/lỗi từ TempData *@
@if (TempData["SuccessMessage"] != null)
{
        <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}
@if (TempData["Error"] != null)
{
        <div class="alert alert-danger">@TempData["Error"]</div>
}
@if (TempData["Message"] != null)
{
        <div class="alert alert-warning">@TempData["Message"]</div>
}


@if (Model == null || !Model.Any())
{
    @* Trường hợp Giỏ hàng trống *@
        <div class="alert alert-info" role="alert">
            Giỏ hàng của bạn hiện đang trống.
        </div>
        <p>
            <a asp-controller="Book" asp-action="Index" class="btn btn-primary">Tiếp tục mua sắm</a>
        </p>
}
else
{
    @* Trường hợp Giỏ hàng có sản phẩm *@
        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Sản phẩm</th>
                    <th>Tác giả</th>
                    <th>Đơn giá</th>
                    <th>Số lượng</th>
                    <th>Thành tiền</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model)
            {
                if (item.MaSachNavigation != null)
                {
                    decimal lineTotal = item.MaSachNavigation.GiaBan * item.SoLuong;
                    total += lineTotal;

                                <tr>
                                    <td>
                                        <a asp-controller="Book" asp-action="Details" asp-route-id="@item.MaSach">
                                @Html.DisplayFor(modelItem => item.MaSachNavigation.TenSach)
                                        </a>
                                    </td>
                                    <td>@Html.DisplayFor(modelItem => item.MaSachNavigation.TacGia)</td>
                                    <td>@String.Format("{0:N0} VNĐ", item.MaSachNavigation.GiaBan)</td>

                        @* CỘT SỐ LƯỢNG: FORM CẬP NHẬT TỰ ĐỘNG *@
                                    <td>
                                        <form asp-controller="Cart" asp-action="UpdateQuantity" method="post" class="d-flex align-items-center">
                                @Html.AntiForgeryToken()
                                            <input type="hidden" name="MaSach" value="@item.MaSach" />
                                @* Input này sẽ tự động submit form khi giá trị thay đổi *@
                                            <input type="number" name="SoLuong" value="@item.SoLuong" min="1" style="width: 70px;" class="form-control me-2" onchange="this.form.submit()" />
                                        </form>
                                    </td>

                                    <td>@String.Format("{0:N0} VNĐ", lineTotal)</td>

                        @* CỘT XÓA: FORM XÓA SẢN PHẨM *@
                                    <td>
                                        <form asp-controller="Cart" asp-action="RemoveItem" method="post">
                                @Html.AntiForgeryToken()
                                            <input type="hidden" name="MaSach" value="@item.MaSach" />
                                            <button type="submit" class="btn btn-sm btn-danger">Xóa</button>
                                        </form>
                                    </td>
                                </tr>
                }
            }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="4" class="text-right"><strong>TỔNG CỘNG:</strong></td>
                    <td><strong>@String.Format("{0:N0} VNĐ", total)</strong></td>
                    <td></td>
                </tr>
            </tfoot>
        </table>

        <div class="d-flex justify-content-between">
            <a asp-controller="Book" asp-action="Index" class="btn btn-secondary">Tiếp tục mua sắm</a>
        @* Nút chuyển đến trang Thanh toán Checkout *@
            <a asp-controller="Checkout" asp-action="Index" class="btn btn-success">Tiến hành Thanh toán</a>
        </div>
}