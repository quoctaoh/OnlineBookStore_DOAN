@model OnlineBookStore_Web.Models.DonHang

@{
    ViewData["Title"] = "Xác Nhận Đặt Hàng";
    decimal total = 0; // Tính toán lại tổng tiền trong View để hiển thị
}

<div class="container text-center py-5">
    <div class="card shadow-sm mx-auto" style="max-width: 600px;">
        <div class="card-header bg-success text-white">
            <h2 class="mb-0"><i class="fas fa-check-circle"></i> ĐẶT HÀNG THÀNH CÔNG!</h2>
        </div>
        <div class="card-body">

            <p class="lead">Cảm ơn bạn đã đặt hàng tại OnlineBookStore_Web.</p>
            <h3 class="text-info">Mã Đơn Hàng Của Bạn: #**@Model.MaDh**</h3>
            <p>Chúng tôi sẽ sớm xác nhận và tiến hành giao hàng tới địa chỉ:</p>

            <div class="alert alert-light border">
                <strong>@Model.DiaChiGiaoHang</strong>
            </div>

            <h5 class="mt-4">Tổng tiền đơn hàng: <strong class="text-danger">@String.Format("{0:N0}", Model.TongTien) VNĐ</strong></h5>

            <a asp-controller="Book" asp-action="Index" class="btn btn-primary mt-3">Tiếp tục mua sắm</a>
            <a asp-controller="Account" asp-action="OrderHistory" class="btn btn-outline-secondary mt-3">Xem lịch sử đơn hàng</a>
        </div>
    </div>
</div>