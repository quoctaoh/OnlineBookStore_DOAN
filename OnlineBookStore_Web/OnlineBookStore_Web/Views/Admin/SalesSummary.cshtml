@{
    ViewData["Title"] = "Báo Cáo Doanh Thu";
    Layout = "_Layout";
    var totalRevenue = (decimal)ViewBag.TotalRevenue;
    var totalOrders = (int)ViewBag.TotalOrders;
    var completedOrders = ViewBag.CompletedOrders as List<OnlineBookStore_Web.Models.DonHang>;
}

<style>
    :root {
        --glass-bg: rgba(255, 255, 255, 0.03);
        --glass-border: rgba(255, 255, 255, 0.1);
        --accent-cyan: #64ffda;
    }

    .page-header {
        border-bottom: 2px solid var(--accent-cyan);
        display: inline-block;
        padding-bottom: 10px;
        margin-bottom: 30px;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    /* Thống kê dạng Card Glass */
    .stat-card-glass {
        background: var(--glass-bg);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        border: 1px solid var(--glass-border);
        border-radius: 24px;
        padding: 30px;
        position: relative;
        overflow: hidden;
        transition: 0.3s;
    }

        .stat-card-glass:hover {
            transform: translateY(-5px);
            border-color: var(--accent-cyan);
        }

    .stat-icon {
        position: absolute;
        right: -10px;
        bottom: -10px;
        font-size: 5rem;
        opacity: 0.1;
        color: var(--accent-cyan);
    }

    .stat-value {
        font-size: 2.5rem;
        font-weight: 800;
        color: var(--accent-cyan);
        margin-top: 10px;
    }

    /* Bảng chi tiết */
    .table-container-glass {
        background: var(--glass-bg);
        backdrop-filter: blur(10px);
        border: 1px solid var(--glass-border);
        border-radius: 20px;
        padding: 25px;
    }

    .table-custom {
        color: #e6f1ff !important;
        margin-bottom: 0;
    }

        .table-custom thead th {
            background: rgba(100, 255, 218, 0.05);
            color: var(--accent-cyan);
            border-bottom: 1px solid var(--glass-border);
            text-transform: uppercase;
            font-size: 0.8rem;
            padding: 15px;
        }

        .table-custom tbody td {
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            padding: 15px;
        }
</style>

<div class="container mt-5 mb-5">
    <div class="mb-4">
        <h2 class="page-header fw-bold text-white mb-0">
            <i class="bi bi-graph-up-arrow me-2"></i>BÁO CÁO DOANH THU
        </h2>
        <p class="text-muted small mt-2">Thống kê dữ liệu dựa trên các đơn hàng đã giao thành công</p>
    </div>

    <div class="row g-4 mb-5">
        @* TỔNG DOANH THU *@
        <div class="col-md-6">
            <div class="stat-card-glass shadow-lg">
                <i class="bi bi-cash-coin stat-icon"></i>
                <h6 class="text-muted text-uppercase fw-bold mb-0">Tổng doanh thu thực tế</h6>
                <div class="stat-value">@String.Format("{0:N0}", totalRevenue) <small style="font-size: 1rem;">VNĐ</small></div>
                <div class="mt-2 text-success small">
                    <i class="bi bi-arrow-up-circle me-1"></i> Tăng trưởng ổn định
                </div>
            </div>
        </div>

        @* TỔNG ĐƠN HÀNG *@
        <div class="col-md-6">
            <div class="stat-card-glass shadow-lg">
                <i class="bi bi-bag-check stat-icon"></i>
                <h6 class="text-muted text-uppercase fw-bold mb-0">Đơn hàng hoàn tất</h6>
                <div class="stat-value">@totalOrders <small style="font-size: 1rem;">Giao dịch</small></div>
                <div class="mt-2 text-info small">
                    <i class="bi bi-info-circle me-1"></i> Không tính đơn đã hủy
                </div>
            </div>
        </div>
    </div>

    <div class="mb-4">
        <h4 class="text-white fw-bold mb-3"><i class="bi bi-list-stars me-2 text-info"></i>Chi tiết lịch sử giao dịch</h4>
        <div class="table-container-glass shadow">
            <div class="table-responsive">
                <table class="table table-custom align-middle">
                    <thead>
                        <tr>
                            <th class="text-center">Mã ĐH</th>
                            <th>Ngày Giao Dịch</th>
                            <th>Khách Hàng</th>
                            <th class="text-end">Số Tiền Thanh Toán</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (completedOrders != null && completedOrders.Any())
                        {
                            @foreach (var order in completedOrders)
                            {
                                <tr>
                                    <td class="text-center fw-bold text-white-50">#@order.MaDh</td>
                                    <td class="text-muted">
                                        @order.NgayDatHang.ToString("dd/MM/yyyy")
                                        <small class="ms-2 opacity-50">@order.NgayDatHang.ToString("HH:mm")</small>
                                    </td>
                                    <td>
                                        <i class="bi bi-person-circle me-2 opacity-75"></i>
                                        @(order.MaNdNavigation?.HoTen ?? "Khách vãng lai")
                                    </td>
                                    <td class="text-end fw-bold" style="color: var(--accent-cyan);">
                                        @String.Format("{0:N0}", order.TongTien) <small>đ</small>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted small italic">Chưa có dữ liệu giao dịch hoàn thành.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="mt-4">
        <a asp-action="Index" class="btn btn-outline-light rounded-pill px-4 btn-sm">
            <i class="bi bi-arrow-left me-2"></i>Quay lại Dashboard
        </a>
    </div>
</div>