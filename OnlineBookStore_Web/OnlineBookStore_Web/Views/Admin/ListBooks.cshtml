@model IEnumerable<OnlineBookStore_Web.Models.Sach>

@{
    ViewData["Title"] = "Quản Lý Sách";
    Layout = "_Layout";
}

<style>
    :root {
        --glass-bg: rgba(255, 255, 255, 0.03);
        --glass-border: rgba(255, 255, 255, 0.1);
        --accent-cyan: #64ffda;
    }

    .page-header {
        border-bottom: 2px solid var(--accent-cyan);
        display: inline-block;
        padding-bottom: 10px;
        margin-bottom: 30px;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .table-container-glass {
        background: var(--glass-bg);
        backdrop-filter: blur(15px);
        border: 1px solid var(--glass-border);
        border-radius: 20px;
        padding: 25px;
    }

    .table-custom { color: #e6f1ff !important; margin-bottom: 0; }
    .table-custom thead th {
        background: rgba(100, 255, 218, 0.1);
        color: var(--accent-cyan);
        text-transform: uppercase;
        font-size: 0.8rem;
        padding: 15px;
    }
    .table-custom tbody td { border-bottom: 1px solid rgba(255, 255, 255, 0.05); padding: 15px; vertical-align: middle; }

    .btn-add-book {
        background: var(--accent-cyan);
        color: #020c1b;
        font-weight: 700;
        border-radius: 10px;
        padding: 10px 20px;
        transition: 0.3s;
        border: none;
    }
    .btn-add-book:hover { background: #fff; transform: translateY(-2px); color: #020c1b; }
    .book-thumb { width: 45px; height: 60px; object-fit: cover; border-radius: 5px; }
    .badge-genre { background: rgba(100, 255, 218, 0.1); color: var(--accent-cyan); border: 1px solid rgba(100, 255, 218, 0.3); }
</style>

<div class="container mt-5 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="page-header fw-bold text-white mb-0">
                <i class="bi bi-book-half me-2"></i>QUẢN LÝ KHO SÁCH
            </h2>
        </div>
        <a asp-action="CreateBook" class="btn btn-add-book">
            <i class="bi bi-plus-circle-fill"></i> THÊM SÁCH MỚI
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success bg-transparent border-success text-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="table-container-glass shadow-lg">
        <div class="table-responsive">
            <table class="table table-custom">
                <thead>
                    <tr>
                        <th class="text-center">ID</th>
                        <th>Hình ảnh</th>
                        <th>Tên Sách</th>
                        <th>Tác Giả</th>
                        <th>Thể Loại</th>
                        <th class="text-end">Giá Bán</th>
                        <th class="text-center">Tồn Kho</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center text-muted small">@item.MaSach</td>
                            <td><img src="@item.HinhAnh" class="book-thumb" onerror="this.src='/images/no-image.png'" /></td>
                            <td class="fw-bold text-white">@item.TenSach</td>
                            <td class="text-muted">@item.TacGia</td>
                            <td><span class="badge badge-genre">@(item.MaTlNavigation?.TenTheLoai ?? "N/A")</span></td>
                            <td class="text-end fw-bold" style="color: var(--accent-cyan);">@String.Format("{0:N0}", item.GiaBan) đ</td>
                            <td class="text-center">@item.SoLuongTon</td>
                            <td class="text-center">
                                <div class="btn-group gap-2">
                                    <a asp-action="EditBook" asp-route-id="@item.MaSach" class="btn btn-sm btn-outline-info rounded-pill px-3">Sửa</a>
                                    <a asp-action="DeleteBook" asp-route-id="@item.MaSach" class="btn btn-sm btn-outline-danger rounded-pill px-3">Xóa</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* NÚT QUAY VỀ Ở CUỐI TRANG *@
    <div class="mt-4">
        <a asp-action="Index" class="btn btn-outline-light rounded-pill px-4 btn-sm">
            <i class="bi bi-arrow-left me-2"></i>Quay lại Dashboard
        </a>
    </div>
</div>