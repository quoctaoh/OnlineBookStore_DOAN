@model IEnumerable<OnlineBookStore_Web.Models.DonHang>

@{
    ViewData["Title"] = "Quản Lý Đơn Hàng";
    Layout = "_Layout";
}

<style>
    :root {
        --glass-bg: rgba(255, 255, 255, 0.03);
        --glass-border: rgba(255, 255, 255, 0.1);
        --accent-cyan: #64ffda;
    }

    .page-header {
        border-bottom: 2px solid var(--accent-cyan);
        display: inline-block;
        padding-bottom: 10px;
        margin-bottom: 30px;
        text-transform: uppercase;
        letter-spacing: 2px;
    }

    .table-container-glass {
        background: var(--glass-bg);
        backdrop-filter: blur(15px);
        border: 1px solid var(--glass-border);
        border-radius: 20px;
        padding: 25px;
    }

    .table-custom { color: #e6f1ff !important; margin-bottom: 0; }
    .table-custom thead th {
        background: rgba(100, 255, 218, 0.1);
        color: var(--accent-cyan);
        text-transform: uppercase;
        font-size: 0.8rem;
        padding: 15px;
    }
    .table-custom tbody td { border-bottom: 1px solid rgba(255, 255, 255, 0.05); padding: 15px; vertical-align: middle; }

    .status-badge { padding: 6px 12px; border-radius: 50px; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; }
    .bg-success-glass { background: rgba(100, 255, 218, 0.1); color: var(--accent-cyan); border: 1px solid rgba(100, 255, 218, 0.3); }
    .bg-info-glass { background: rgba(0, 184, 212, 0.1); color: #00e5ff; border: 1px solid rgba(0, 184, 212, 0.3); }
    .bg-warning-glass { background: rgba(255, 193, 7, 0.1); color: #ffc107; border: 1px solid rgba(255, 193, 7, 0.3); }
</style>

<div class="container mt-5 mb-5">
    <div class="mb-4">
        <h2 class="page-header fw-bold text-white mb-0">
            <i class="bi bi-cart-check me-2"></i>QUẢN LÝ ĐƠN HÀNG
        </h2>
    </div>

    <div class="table-container-glass shadow-lg">
        <div class="table-responsive">
            <table class="table table-custom align-middle">
                <thead>
                    <tr>
                        <th class="text-center">Mã ĐH</th>
                        <th>Khách hàng</th>
                        <th>Ngày Đặt</th>
                        <th class="text-end">Tổng Tiền</th>
                        <th>Trạng Thái</th>
                        <th class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-center fw-bold text-white-50">#@item.MaDh</td>
                            <td>
                                <div class="fw-bold text-white">@(item.MaNdNavigation?.HoTen ?? "N/A")</div>
                                <div class="text-muted small">@item.DiaChiGiaoHang</div>
                            </td>
                            <td class="text-muted">@item.NgayDatHang.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="text-end fw-bold" style="color: var(--accent-cyan);">@String.Format("{0:N0}", item.TongTien) đ</td>
                            <td>
                                @{
                                    var statusClass = item.TrangThaiDh == "Đã giao thành công" ? "bg-success-glass" : item.TrangThaiDh == "Đang giao hàng" ? "bg-info-glass" : "bg-warning-glass";
                                }
                                <span class="status-badge @statusClass">@item.TrangThaiDh</span>
                            </td>
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-2">
                                    <a asp-action="OrderDetails" asp-route-id="@item.MaDh" class="btn btn-sm btn-outline-info"><i class="bi bi-eye"></i></a>
                                    <a asp-action="EditStatus" asp-route-id="@item.MaDh" class="btn btn-sm btn-outline-primary"><i class="bi bi-arrow-repeat"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @* NÚT QUAY VỀ Ở CUỐI TRANG *@
    <div class="mt-4">
        <a asp-action="Index" class="btn btn-outline-light rounded-pill px-4 btn-sm">
            <i class="bi bi-arrow-left me-2"></i>Quay lại Dashboard
        </a>
    </div>
</div>