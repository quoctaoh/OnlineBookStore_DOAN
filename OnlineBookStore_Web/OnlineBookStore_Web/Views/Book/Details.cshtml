@model OnlineBookStore_Web.Models.Sach
@{
    ViewData["Title"] = Model.TenSach;
}

<style>
    :root {
        --navy-darkest: #020c1b;
        --navy-deep: #0a192f;
        --navy-soft: #112240;
        --accent-cyan: #64ffda;
        --text-bright: #e6f1ff;
        --text-dim: #8892b0;
        --glass-bg: rgba(255, 255, 255, 0.05);
        --glass-border: rgba(255, 255, 255, 0.1);
    }

    body {
        background-color: var(--navy-darkest) !important;
        color: var(--text-bright);
    }

    .product-image-glass {
        background: var(--glass-bg) !important;
        backdrop-filter: blur(15px);
        border: 1px solid var(--glass-border);
    }

    .img-main-container {
        background: #fff;
        border-radius: 15px;
        padding: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .price-box-glass {
        background: rgba(100, 255, 218, 0.05) !important;
        border-left: 4px solid var(--accent-cyan);
        border-radius: 12px;
    }

    .purchase-box-glass {
        background: var(--glass-bg) !important;
        backdrop-filter: blur(10px);
        border: 1px solid var(--glass-border);
        border-radius: 20px;
    }

    .quantity-picker-dark {
        background: var(--navy-soft);
        border: 1px solid var(--glass-border);
        border-radius: 10px;
    }

    .quantity-picker-dark button { color: var(--accent-cyan) !important; background: transparent !important; }
    .quantity-picker-dark input { background: transparent !important; color: #fff !important; border: none !important; }

    .btn-add-cart { border: 1px solid var(--accent-cyan) !important; color: var(--accent-cyan) !important; transition: 0.3s; }
    .btn-add-cart:hover { background: rgba(100, 255, 218, 0.1) !important; }
    .btn-buy-now { background: var(--accent-cyan) !important; color: var(--navy-darkest) !important; border: none !important; }

    .star-rating-dark { display: flex; flex-direction: row-reverse; justify-content: flex-end; }
    .star-rating-dark input { display: none; }
    .star-rating-dark label { color: var(--navy-soft); cursor: pointer; font-size: 1.5rem; transition: 0.2s; }
    .star-rating-dark input:checked ~ label, .star-rating-dark label:hover ~ label { color: var(--accent-cyan); }
    .comment-box { background: var(--navy-soft) !important; color: #fff !important; border: 1px solid var(--glass-border) !important; }
</style>

<div class="container mt-5 mb-5">
    @* --- PHẦN 1: THÔNG TIN CHI TIẾT SÁCH --- *@
    <div class="row g-5">
        <div class="col-lg-5">
            <div class="product-image-glass p-3 rounded-4 text-center sticky-top" style="top: 100px; z-index: 1;">
                <div class="img-main-container shadow-sm">
                    <img src="@Model.HinhAnh" alt="@Model.TenSach" class="img-fluid rounded-3" onerror="this.src='/images/no-image.png'"/>
                </div>
            </div>
        </div>

        <div class="col-lg-7">
            <h1 class="display-6 fw-bold mb-2 text-white">@Model.TenSach</h1>
            
            <div class="price-box-glass p-4 mb-4">
                <h2 style="color: var(--accent-cyan);" class="fw-bold mb-0">@Model.GiaBan.ToString("N0") <span class="fs-4">VNĐ</span></h2>
            </div>

            <div class="row mb-4 text-white">
                <div class="col-6 mb-3">
                    <p class="mb-0 text-muted small">Tác giả</p>
                    <p class="fw-bold mb-0">@Model.TacGia</p>
                </div>
                <div class="col-6 mb-3">
                    <p class="mb-0 text-muted small">Thể loại</p>
                    <p class="fw-bold mb-0" style="color: var(--accent-cyan);">@(Model.MaTlNavigation?.TenTheLoai ?? "Đang cập nhật")</p>
                </div>
                <div class="col-6 mb-3">
                    <p class="mb-0 text-muted small">Nhà xuất bản</p>
                    <p class="fw-bold mb-0">@(Model.MaNxbNavigation?.TenNxb ?? "Đang cập nhật")</p>
                </div>
                <div class="col-6 mb-3">
                    <p class="mb-0 text-muted small">Tình trạng</p>
                    <p class="fw-bold mb-0 @(Model.SoLuongTon > 0 ? "text-success" : "text-danger")">
                         @(Model.SoLuongTon > 0 ? $"Còn hàng ({Model.SoLuongTon})" : "Hết hàng")
                    </p>
                </div>
            </div>

            <div class="purchase-box-glass p-4 mb-5 shadow-sm">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="quantity-picker-dark d-flex align-items-center overflow-hidden">
                        <button class="btn border-0 px-3 py-2" onclick="changeQty(-1)"><i class="bi bi-dash-lg"></i></button>
                        <input type="number" id="SoLuongInput" value="1" min="1" max="@Model.SoLuongTon" 
                               class="form-control text-center fw-bold shadow-none" style="width: 60px;" readonly />
                        <button class="btn border-0 px-3 py-2" onclick="changeQty(1)"><i class="bi bi-plus-lg"></i></button>
                    </div>
                </div>

                <div class="row g-2">
                    <div class="col-6">
                        <button class="btn btn-add-cart w-100 py-3 fw-bold rounded-3" onclick="ajaxAddToCart(@Model.MaSach)">
                            <i class="bi bi-cart-plus me-2"></i>Thêm giỏ hàng
                        </button>
                    </div>
                    <div class="col-6">
                        <form asp-controller="Cart" asp-action="BuyNow" method="post" onsubmit="syncQuantity()">
                            <input type="hidden" name="MaSach" value="@Model.MaSach" />
                            <input type="hidden" name="SoLuong" id="BuyNowQuantity" value="1" />
                            <button type="submit" class="btn btn-buy-now w-100 py-3 fw-bold rounded-3 shadow">
                                MUA NGAY
                            </button>
                        </form>
                    </div>
                </div>
            </div>

            <div class="description-section">
                <h5 class="fw-bold border-bottom border-secondary pb-2 mb-3" style="color: var(--accent-cyan);">Giới thiệu nội dung</h5>
                <div class="text-dim" style="line-height: 1.8;">@Model.MoTa</div>
            </div>
        </div>
    </div>

    @* --- PHẦN 2: KHU VỰC ĐÁNH GIÁ & NHẬN XÉT --- *@
    <div class="row mt-5">
        <div class="col-lg-8">
            <div class="purchase-box-glass p-4 mb-4">
                <h4 class="fw-bold mb-4 text-white"><i class="bi bi-chat-left-dots me-2"></i>Khách hàng nhận xét</h4>

                @* Form gửi đánh giá *@
                @if (ViewBag.IsLoggedIn == false)
                {
                    <div class="alert alert-warning border-0 rounded-4 py-3">
                        <i class="bi bi-lock-fill me-2"></i> Vui lòng <a asp-controller="Account" asp-action="Login" class="fw-bold text-dark">Đăng nhập</a> để gửi đánh giá.
                    </div>
                }
                else if (ViewBag.HasPurchased == true)
                {
                    <form asp-controller="Cart" asp-action="PostReview" method="post" class="mb-5">
                        <input type="hidden" name="MaSach" value="@Model.MaSach" />
                        <div class="star-rating-dark mb-3">
                            <input type="radio" name="Rating" value="5" id="rate-5" required checked><label for="rate-5" class="bi bi-star-fill"></label>
                            <input type="radio" name="Rating" value="4" id="rate-4"><label for="rate-4" class="bi bi-star-fill"></label>
                            <input type="radio" name="Rating" value="3" id="rate-3"><label for="rate-3" class="bi bi-star-fill"></label>
                            <input type="radio" name="Rating" value="2" id="rate-2"><label for="rate-2" class="bi bi-star-fill"></label>
                            <input type="radio" name="Rating" value="1" id="rate-1"><label for="rate-1" class="bi bi-star-fill"></label>
                        </div>
                        <textarea name="NoiDung" class="form-control comment-box mb-3 p-3 rounded-4 shadow-none" rows="3" placeholder="Chia sẻ cảm nhận của bạn về cuốn sách này..." required></textarea>
                        <button type="submit" class="btn btn-buy-now px-5 py-2 rounded-pill fw-bold">Gửi đánh giá</button>
                    </form>
                }
                else
                {
                    <div class="alert border-0 rounded-4 py-3 mb-5" style="background: rgba(100, 255, 218, 0.1); color: var(--accent-cyan);">
                        <i class="bi bi-shield-lock-fill me-2"></i> 
                        <strong>Quyền đánh giá bị hạn chế:</strong> Bạn cần mua sách này để có thể gửi nhận xét.
                    </div>
                }

                @* Danh sách nhận xét *@
                <h5 class="fw-bold mb-4 text-white">Độc giả nói gì (@(Model.DanhGias?.Count ?? 0))</h5>
                @if (Model.DanhGias != null && Model.DanhGias.Any())
                {
                    @foreach (var dg in Model.DanhGias.OrderByDescending(x => x.NgayDanhGia))
                    {
                        <div class="purchase-box-glass p-4 mb-3" style="background: rgba(255,255,255,0.02) !important;">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <span class="fw-bold text-white">@dg.MaNdNavigation?.HoTen</span>
                                    <span class="badge bg-success ms-2" style="font-size: 0.6rem;">✅ Đã mua</span>
                                </div>
                                <span class="text-muted small">@dg.NgayDanhGia.ToString("dd/MM/yyyy")</span>
                            </div>
                            <div class="text-warning small mb-2">
                                @for (int i = 1; i <= dg.SoSao; i++)
                                {
                                    <i class="bi bi-star-fill"></i>
                                }
                            </div>
                            <p class="text-dim mb-0">@dg.NoiDung</p>
                        </div>
                    }
                }
                else
                {
                    <p class="text-muted italic">Chưa có đánh giá nào cho cuốn sách này.</p>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // 1. Hàm thay đổi số lượng
        function changeQty(val) {
            let input = $('#SoLuongInput');
            let current = parseInt(input.val()) || 1;
            let next = current + val;
            if (next >= 1 && next <= @Model.SoLuongTon) {
                input.val(next);
            }
        }

        // 2. Đồng bộ số lượng sang form Mua ngay
        function syncQuantity() {
            $('#BuyNowQuantity').val($('#SoLuongInput').val());
        }

        // 3. Hàm AJAX thêm giỏ hàng (Thông báo giữa trang + Chuyển hướng)
        function ajaxAddToCart(id) {
            var qty = parseInt($('#SoLuongInput').val()) || 1;
            
            $.post('/Cart/AddToCart', { MaSach: id, SoLuong: qty }, function (res) {
                if (res.success) {
                    // Cập nhật Navbar badge
                    var badge = $('#cart-count'); 
                    if(badge.length > 0) {
                        var currentCount = parseInt(badge.text()) || 0;
                        badge.text(currentCount + qty);
                    }
                    
                    // Hiện thông báo ở GIỮA trang
                    if (typeof notifySuccess === "function") {
                        notifySuccess("Đã thêm " + qty + " sản phẩm vào giỏ!");
                    } else {
                        Swal.fire({
                            icon: 'success',
                            title: 'Thành công!',
                            text: "Đã thêm vào giỏ hàng!",
                            position: 'center',
                            showConfirmButton: false,
                            timer: 2000,
                            background: '#112240',
                            color: '#64ffda'
                        });
                    }
                } 
                else if (res.redirect) {
                    // Xử lý chuyển hướng đăng nhập
                    Swal.fire({
                        title: 'Yêu cầu đăng nhập',
                        text: "Bạn cần đăng nhập để thêm sản phẩm vào giỏ hàng!",
                        icon: 'info',
                        background: '#0a192f',
                        color: '#fff',
                        confirmButtonColor: '#64ffda',
                        confirmButtonText: 'Đăng nhập ngay',
                        showCancelButton: true,
                        cancelButtonText: 'Để sau'
                    }).then((result) => {
                        if (result.isConfirmed) {
                            window.location.href = '/Account/Login';
                        }
                    });
                } 
                else {
                    Swal.fire({
                        icon: 'error',
                        title: 'Lỗi...',
                        text: res.message,
                        background: '#0a192f',
                        color: '#fff'
                    });
                }
            });
        }
    </script>
}