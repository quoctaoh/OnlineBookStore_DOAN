@model IEnumerable<OnlineBookStore_Web.Models.Sach>

@{
    ViewData["Title"] = "Danh Mục Sách";
    List<OnlineBookStore_Web.Models.TheLoai>? categories = ViewBag.Categories as List<OnlineBookStore_Web.Models.TheLoai>;

    int currentCategoryId = ViewBag.CurrentCategory != null ? (int)ViewBag.CurrentCategory : 0;

    string? currentSearch = ViewBag.CurrentSearch;
}

<h1>Danh Mục Sách</h1>

<div class="row mb-4">
    <div class="col-md-3">
        <form asp-controller="Book" asp-action="Index" method="get">
            <h4 class="mt-2">Lọc theo Thể loại</h4>

            <div class="list-group">
                @* Nút Tất cả (Active khi currentCategoryId = 0) *@
                <button type="submit" name="categoryId" value="" 
                        class="list-group-item list-group-item-action @((currentCategoryId == 0) ? "active" : "")">
                    Tất cả
                </button>

                @if (categories != null)
                {
                    @foreach (var category in categories)
                    {
                                <button type="submit" name="categoryId" value="@category.MaTl" 
                                        class="list-group-item list-group-item-action @((currentCategoryId == category.MaTl) ? "active" : "")">
                            @category.TenTheLoai
                                </button>
                    }
                }
            </div>
        </form>
    </div>

    <div class="col-md-9">
        <form asp-controller="Book" asp-action="Index" method="get" class="mb-3">
            <div class="input-group">
                <input type="text" name="searchString" value="@currentSearch" 
                        class="form-control" placeholder="Tìm kiếm theo Tên Sách hoặc Tác giả..." />
                <button type="submit" class="btn btn-primary">Tìm</button>
            </div>
        </form>

        <table class="table">
            <thead>
                <tr>
                    <th>Ảnh Bìa</th> 
                    <th>Tên Sách</th>
                    <th>Tác Giả</th>
                    <th>Giá Bán</th>
                    <th>Tồn Kho</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                        <tr>
                            <td>
                                <img src="@item.HinhAnh" alt="@item.TenSach" style="width: 50px; height: auto; object-fit: cover;" />
                            </td>
                            <td>@Html.DisplayFor(modelItem => item.TenSach)</td>
                            <td>@Html.DisplayFor(modelItem => item.TacGia)</td>
                            <td>@String.Format("{0:N0} VNĐ", item.GiaBan)</td>
                            <td>@Html.DisplayFor(modelItem => item.SoLuongTon)</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.MaSach">Chi Tiết</a>
                            </td>
                        </tr>
                }
            </tbody>
        </table>
    </div>
</div>