@model IEnumerable<OnlineBookStore_Web.Models.Sach>

@{
    ViewData["Title"] = "Danh Mục Sách";
    var categories = ViewBag.Categories as List<OnlineBookStore_Web.Models.TheLoai>;
    int currentCategoryId = ViewBag.CurrentCategory ?? 0;
    string currentSort = ViewBag.CurrentSort ?? "";
}

<style>
    :root {
        --navy-darkest: #020c1b;
        --navy-deep: #0a192f;
        --navy-soft: #112240;
        --accent-cyan: #64ffda;
        --text-bright: #e6f1ff;
        --text-dim: #8892b0;
    }

    body { background-color: var(--navy-darkest) !important; color: var(--text-bright); }

    /* Header & Sorting */
    .catalog-header {
        display: flex; justify-content: space-between; align-items: center;
        margin-bottom: 25px; padding-bottom: 15px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    .sort-select {
        background: var(--navy-soft); color: var(--text-bright);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 8px; padding: 6px 12px; font-size: 0.85rem;
    }

    /* Sidebar Glassmorphism */
    .category-sidebar {
        background: var(--navy-deep); border-radius: 16px; padding: 20px;
        border: 1px solid rgba(255, 255, 255, 0.1); position: sticky; top: 100px;
    }
    .filter-label {
        color: var(--accent-cyan); font-size: 0.75rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 1px; margin-bottom: 15px; display: block;
    }

    /* List Group */
    .list-group-item {
        background: transparent !important; color: var(--text-dim) !important;
        border: none !important; font-size: 0.9rem; padding: 8px 12px;
        transition: 0.3s; text-align: left; width: 100%;
    }
    .list-group-item:hover, .list-group-item.active {
        color: var(--accent-cyan) !important; background: rgba(100, 255, 218, 0.05) !important;
    }

    /* Price Inputs */
    .price-range-input {
        background: var(--navy-soft); border: 1px solid rgba(255, 255, 255, 0.1);
        color: var(--accent-cyan); border-radius: 8px; width: 100%;
        padding: 8px; margin-bottom: 10px; font-size: 0.85rem;
    }
    .btn-apply {
        background: var(--accent-cyan); color: var(--navy-darkest);
        border: none; width: 100%; border-radius: 8px; font-weight: 700; padding: 10px;
    }

    /* Card Sách */
    .book-card {
        background: var(--navy-soft); border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 12px; transition: 0.3s; height: 100%;
    }
    .book-card:hover { border-color: var(--accent-cyan); transform: translateY(-5px); }
    .img-container { background: #fff; border-radius: 8px 8px 0 0; padding: 10px; }
    .img-container img { width: 100%; height: 160px; object-fit: contain; }
    .book-title { font-size: 0.85rem; font-weight: 600; color: var(--text-bright); height: 2.4rem; overflow: hidden; }
    .book-price { color: var(--accent-cyan); font-weight: 700; }
    .btn-detail { background: rgba(255,255,255,0.05); color: var(--text-dim) !important; font-size: 0.7rem; border: 1px solid rgba(255,255,255,0.1); }
    .btn-detail:hover { background: var(--accent-cyan); color: var(--navy-darkest) !important; }
</style>

<div class="container py-5">
    <div class="row g-4">
        <div class="col-lg-3 col-xl-2">
            <div class="category-sidebar">
                <form id="mainFilterForm" asp-controller="Book" asp-action="Index" method="get">
                    <span class="filter-label">Thể loại</span>
                    <div class="list-group mb-4">
                        <button type="submit" name="categoryId" value="" 
                                class="list-group-item @(currentCategoryId == 0 ? "active" : "")">Tất cả</button>
                        @if (categories != null) {
                            @foreach (var cat in categories) {
                                <button type="submit" name="categoryId" value="@cat.MaTl" 
                                        class="list-group-item @(currentCategoryId == cat.MaTl ? "active" : "")">
                                    @cat.TenTheLoai
                                </button>
                            }
                        }
                    </div>

                  
                </form>
            </div>
        </div>

        <div class="col-lg-9 col-xl-10">
            <div class="catalog-header">
                <h2 class="page-title">DANH MỤC SÁCH</h2>
                
                <div class="d-flex align-items-center">
                    <span class="small text-muted me-2">Sắp xếp:</span>
                    <select class="sort-select" id="sortDropdown">
                        <option value="">Mặc định</option>
                        <option value="price_asc" selected='@(currentSort == "price_asc")'>Giá: Thấp đến Cao</option>
                        <option value="price_desc" selected='@(currentSort == "price_desc")'>Giá: Cao đến Thấp</option>
                    </select>
                </div>
            </div>

            <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-5 g-3">
                @foreach (var item in Model) {
                    <div class="col">
                        <div class="card book-card">
                            <div class="img-container"><img src="@item.HinhAnh" alt="@item.TenSach" /></div>
                            <div class="card-body d-flex flex-column p-3">
                                <h5 class="book-title">@item.TenSach</h5>
                                <div class="mt-auto">
                                    <div class="book-price">@String.Format("{0:N0}", item.GiaBan) đ</div>
                                    <a asp-action="Details" asp-route-id="@item.MaSach" class="btn btn-detail w-100 mt-2">CHI TIẾT</a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>
    // Script để đồng bộ hóa dropdown Sorting với Form lọc chính
    document.getElementById('sortDropdown').addEventListener('change', function() {
        // Cập nhật giá trị vào input ẩn trong form
        document.getElementById('hiddenSortOrder').value = this.value;
        // Submit form để lọc và sắp xếp cùng lúc
        document.getElementById('mainFilterForm').submit();
    });
</script>