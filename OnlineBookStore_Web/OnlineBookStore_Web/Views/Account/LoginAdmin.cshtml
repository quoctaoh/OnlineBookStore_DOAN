@model OnlineBookStore_Web.Models.Admin

@{
    ViewData["Title"] = "Đăng Nhập Quản Trị";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <style>
            :root {
                --navy-bg: #0a192f;
                --navy-darkest: #020c1b;
                --accent-cyan: #64ffda;
                --glass-white: rgba(255, 255, 255, 0.05);
                --glass-border: rgba(255, 255, 255, 0.1);
            }

            body {
                background-color: var(--navy-darkest) !important;
                color: #e6f1ff;
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                height: 100vh;
                display: flex;
                align-items: center;
                justify-content: center;
                margin: 0;
                background: radial-gradient(circle at 50% 50%, #0a192f 0%, #020c1b 100%);
            }

            .login-glass-card {
                background: rgba(17, 34, 64, 0.7);
                backdrop-filter: blur(20px);
                -webkit-backdrop-filter: blur(20px);
                border: 1px solid var(--glass-border);
                border-radius: 24px;
                padding: 40px;
                width: 100%;
                max-width: 400px;
                box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
            }

            .login-header i {
                font-size: 3rem;
                color: var(--accent-cyan);
                text-shadow: 0 0 20px rgba(100, 255, 218, 0.3);
            }

            .form-label-custom {
                font-size: 0.8rem;
                font-weight: 600;
                color: var(--accent-cyan);
                text-transform: uppercase;
                letter-spacing: 1px;
                margin-bottom: 8px;
            }

            .form-control-glass {
                background: rgba(2, 12, 27, 0.5) !important;
                border: 1px solid var(--glass-border) !important;
                color: white !important;
                border-radius: 12px !important;
                padding: 12px 15px !important;
                transition: 0.3s;
            }

                .form-control-glass:focus {
                    border-color: var(--accent-cyan) !important;
                    box-shadow: 0 0 15px rgba(100, 255, 218, 0.1) !important;
                    outline: none;
                }

            .btn-admin-login {
                background: var(--accent-cyan) !important;
                color: var(--navy-darkest) !important;
                border: none !important;
                border-radius: 12px !important;
                padding: 14px !important;
                font-weight: 800 !important;
                text-transform: uppercase !important;
                letter-spacing: 1px !important;
                transition: 0.3s !important;
                margin-top: 10px;
            }

                .btn-admin-login:hover {
                    transform: translateY(-3px);
                    box-shadow: 0 10px 20px rgba(100, 255, 218, 0.2);
                    background: white !important;
                }

            .back-link {
                color: #8892b0;
                text-decoration: none;
                font-size: 0.9rem;
                transition: 0.3s;
            }

                .back-link:hover {
                    color: var(--accent-cyan);
                }

            /* Tùy chỉnh lỗi Validation */
            .validation-summary-errors ul {
                list-style: none;
                padding: 0;
                font-size: 0.85rem;
            }
    </style>
</head>
<body>
    <div class="login-glass-card text-center">
        <div class="login-header mb-4">
            <i class="bi bi-shield-lock-fill"></i>
            <h3 class="fw-bold mt-3 mb-1 text-white">ADMIN PANEL</h3>
            <p class="text-muted small">Vui lòng xác thực quyền quản trị</p>
        </div>

        <form asp-action="LoginAdmin" method="post" class="text-start">
            <div asp-validation-summary="All" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="TenDangNhap" class="form-label-custom">Tên đăng nhập</label>
                <input asp-for="TenDangNhap" class="form-control-glass w-100" placeholder="Username" autocomplete="off" />
                <span asp-validation-for="TenDangNhap" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="MatKhau" class="form-label-custom">Mật khẩu</label>
                <input asp-for="MatKhau" class="form-control-glass w-100" type="password" placeholder="••••••••" />
                <span asp-validation-for="MatKhau" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn-admin-login w-100">
                Đăng Nhập Hệ Thống <i class="bi bi-arrow-right-short"></i>
            </button>
        </form>

        <div class="mt-4 pt-3 border-top border-secondary border-opacity-25">
            <a asp-controller="Home" asp-action="Index" class="back-link">
                <i class="bi bi-house-door me-1"></i> Quay lại Trang chủ
            </a>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
</body>
</html>