@model OnlineBookStore_Web.Models.Admin

@{
    ViewData["Title"] = "Đăng Nhập Quản Trị";
    // BẮT BUỘC: Không sử dụng Layout chính
    Layout = null; 
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div class="container" style="max-width: 400px; margin-top: 100px;">
        <h2 class="text-center text-primary mb-4">Đăng Nhập Quản Trị Hệ Thống</h2>
        <div class="card shadow">
            <div class="card-body">
                <form asp-action="LoginAdmin" method="post">
                   <div asp-validation-summary="All" class="text-danger"></div>

                    @* Trường Tên đăng nhập *@
                    <div class="form-group mb-3">
                        <label asp-for="TenDangNhap" class="control-label"></label>
                        <input asp-for="TenDangNhap" class="form-control" />
                        <span asp-validation-for="TenDangNhap" class="text-danger"></span>
                    </div>

                    @* Trường Mật khẩu *@
                    <div class="form-group mb-3">
                        <label asp-for="MatKhau" class="control-label"></label>
                        <input asp-for="MatKhau" class="form-control" type="password" />
                        <span asp-validation-for="MatKhau" class="text-danger"></span>
                    </div>

                    <div class="form-group mt-4">
                        <button type="submit" class="btn btn-primary w-100">Đăng Nhập</button>
                    </div>
                </form>
            </div>
        </div>
        <div class="text-center mt-3">
            <a asp-controller="Home" asp-action="Index">Quay lại Trang chủ</a>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    } 
</body>
</html>