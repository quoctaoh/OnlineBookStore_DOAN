@{
    ViewData["Title"] = "Xác Thực OTP";
}

<div class="container mt-5" style="max-width: 500px;">
    <div class="card shadow">
        <div class="card-body text-center">
            <h3 class="text-primary mb-3">Xác Thực Tài Khoản</h3>
            <p>Chúng tôi đã gửi mã OTP 6 số đến email: <strong>@ViewBag.Email</strong></p>

            @if (ViewBag.Error != null)
            {
                    <div class="alert alert-danger">@ViewBag.Error</div>
            }

            <form asp-action="VerifyOtp" method="post">
                <input type="hidden" name="email" value="@ViewBag.Email" />

                <div class="form-group mb-3">
                    <input type="text" name="otpInput" class="form-control text-center" 
                           placeholder="Nhập mã OTP" required maxlength="6" style="font-size: 1.5rem; letter-spacing: 5px;" />
                </div>

                <button type="submit" class="btn btn-success w-100">Xác Nhận</button>
            </form>

            <div class="mt-3">
                <a asp-action="Register">Đăng ký lại</a>
            </div>
        </div>
    </div>
</div>