@model OnlineBookStore_Web.Models.NguoiDung
@{
    Layout = null; 
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng Nhập - OnlineBookStore</title>
    
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Inter:wght@400;600;700&display=swap');

        :root {
            --navy-darkest: #020c1b;
            --navy-deep: #0a192f;
            --navy-soft: #112240;
            --accent-cyan: #64ffda;
            --glass-bg: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 255, 255, 0.1);
        }

        body {
            background-color: var(--navy-darkest);
            /* Hiệu ứng tia sáng mờ ở góc */
            background-image: radial-gradient(circle at 0% 0%, rgba(100, 255, 218, 0.05) 0%, transparent 50%),
                              radial-gradient(circle at 100% 100%, rgba(59, 130, 246, 0.05) 0%, transparent 50%);
            font-family: 'Inter', sans-serif;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            color: #e6f1ff;
        }

        .split-screen {
            width: 90%;
            max-width: 900px;
            height: 550px; 
            display: flex;
            background: var(--navy-deep);
            border-radius: 28px;
            overflow: hidden;
            border: 1px solid var(--glass-border);
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        }

        /* --- BÊN TRÁI: FORM ĐĂNG NHẬP (GLASS) --- */
        .login-section {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2.5rem;
            position: relative;
            background: linear-gradient(135deg, rgba(255,255,255,0.02) 0%, transparent 100%);
        }

        .login-container {
            width: 100%;
            max-width: 300px;
        }

        .brand-logo {
            color: var(--accent-cyan);
            font-size: 1.5rem;
            font-weight: 800;
            text-decoration: none;
            display: inline-block;
            margin-bottom: 1.5rem;
            letter-spacing: -0.5px;
        }

        /* Ô NHẬP LIỆU STYLE NAVY GLASS */
        .form-control-minimal {
            border: 1px solid var(--glass-border);
            border-radius: 12px;
            padding: 0.75rem 1rem;
            font-size: 0.9rem;
            transition: all 0.3s ease;
            background-color: var(--navy-soft);
            color: #fff;
        }

        .form-control-minimal:focus {
            box-shadow: 0 0 15px rgba(100, 255, 218, 0.1);
            border-color: var(--accent-cyan);
            background-color: rgba(17, 34, 64, 0.8);
            outline: none;
        }

        .form-control-minimal::placeholder {
            color: rgba(255,255,255,0.3);
        }

        .form-label-minimal {
            font-weight: 600;
            color: var(--accent-cyan);
            text-transform: uppercase;
            font-size: 0.7rem;
            letter-spacing: 1.5px;
            margin-bottom: 0.5rem;
            display: block;
            opacity: 0.8;
        }

        .btn-cyan {
            background: var(--accent-cyan);
            color: var(--navy-darkest);
            font-weight: 700;
            border: none;
            border-radius: 12px;
            padding: 0.85rem;
            font-size: 0.9rem;
            letter-spacing: 1px;
            transition: 0.3s;
            width: 100%;
        }

        .btn-cyan:hover {
            background: #ffffff;
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(100, 255, 218, 0.2);
        }

        /* --- BÊN PHẢI: POSTER --- */
        .poster-section {
            flex: 1.2;
            position: relative;
            border-left: 1px solid var(--glass-border);
        }

        #posterCarousel, .carousel-inner, .carousel-item {
            height: 100%;
        }

        .carousel-item img {
            height: 100%;
            width: 100%;
            object-fit: cover;
            filter: brightness(0.7) contrast(1.1);
        }

        .carousel-overlay {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            background: linear-gradient(to bottom, transparent 0%, var(--navy-darkest) 100%);
            opacity: 0.6;
        }

        .carousel-caption-custom {
            position: absolute;
            bottom: 15%; left: 10%; right: 10%;
            color: #fff;
            text-align: left;
            z-index: 10;
        }

        .poster-title {
            font-family: 'Playfair Display', serif;
            font-size: 2.2rem;
            margin-bottom: 0.8rem;
            color: var(--accent-cyan);
        }

        .poster-desc {
            font-size: 0.9rem;
            color: rgba(255,255,255,0.7);
            line-height: 1.6;
            max-width: 320px;
        }

        @@media (max-width: 850px) {
            .poster-section { display: none; }
            .split-screen { max-width: 450px; height: auto; }
        }
    </style>
</head>
<body>

<div class="split-screen animate__animated animate__fadeIn">
    @* --- TRÁI: KHỐI NHẬP LIỆU --- *@
    <div class="login-section">
        <div class="login-container">
            <div class="text-center">
                <a href="/" class="brand-logo"><i class="bi bi-bookmarks-fill me-2"></i>BOOKSTORE</a>
                <h4 class="fw-bold mb-1" style="font-family: 'Playfair Display', serif; color: #fff;">Chào Mừng Trở Lại</h4>
                <p class="small mb-4" style="color: var(--text-dim);">Đăng nhập để tiếp tục hành trình tri thức</p>
            </div>

            <form asp-action="Login" method="post">
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2 px-3 mb-3 border-0 rounded-3" style="font-size: 0.75rem; background: rgba(239, 68, 68, 0.1); color: #f87171;">
                        <i class="bi bi-exclamation-circle me-2"></i>
                        <div asp-validation-summary="ModelOnly" class="d-inline"></div>
                    </div>
                }

                <div class="mb-3">
                    <label asp-for="TenDangNhap" class="form-label-minimal">Tên Đăng Nhập</label>
                    <input asp-for="TenDangNhap" class="form-control-minimal w-100 shadow-none" placeholder="Nhập username..." required />
                </div>

                <div class="mb-2">
                    <label asp-for="MatKhau" class="form-label-minimal">Mật Khẩu</label>
                    <div class="position-relative">
                        <input asp-for="MatKhau" id="passwordInput" type="password" class="form-control-minimal w-100 shadow-none" placeholder="••••••••" required />
                        <button class="btn bg-transparent border-0 text-white-50 p-0 shadow-none" type="button" id="togglePassword" style="position: absolute; right: 1rem; top: 50%; transform: translateY(-50%);">
                            <i class="bi bi-eye" id="toggleIcon"></i>
                        </button>
                    </div>
                </div>

                <div class="text-end mb-4">
                    <a asp-action="ForgotPassword" class="text-decoration-none" style="font-size: 0.75rem; color: var(--accent-cyan); opacity: 0.8;">Quên mật khẩu?</a>
                </div>

                <div class="d-grid mb-4">
                    <button type="submit" class="btn btn-cyan text-uppercase">Đăng Nhập</button>
                </div>
            </form>

            <div class="text-center pt-3 border-top border-secondary opacity-75">
                <p style="font-size: 0.8rem; color: var(--text-dim);">Chưa có tài khoản? <a asp-action="Register" class="fw-bold text-decoration-none" style="color: var(--accent-cyan);">Đăng ký</a></p>
            </div>
            
            <div class="text-center mt-3">
                <a href="/" class="small text-decoration-none" style="color: var(--text-dim);"><i class="bi bi-house-door me-1"></i>Về trang chủ</a>
            </div>
        </div>
    </div>

    @* --- PHẢI: POSTER QUẢNG CÁO --- *@
    <div class="poster-section">
        <div id="posterCarousel" class="carousel slide carousel-fade h-100" data-bs-ride="carousel">
            <div class="carousel-inner h-100">
                <div class="carousel-item active h-100">
                    <div class="carousel-overlay"></div>
                    <img src="~/images/BannerChinh.jpg" alt="Book 1" class="h-100">
                    <div class="carousel-caption-custom">
                        <h2 class="poster-title">Tri Thức Vô Tận</h2>
                        <p class="poster-desc">Khám phá hàng ngàn tác phẩm chọn lọc từ những tác giả danh tiếng nhất.</p>
                    </div>
                </div>
                <div class="carousel-item h-100">
                    <div class="carousel-overlay"></div>
                    <img src="~/images/DacNhanTam.jpg" alt="Book 2" class="h-100">
                    <div class="carousel-caption-custom">
                        <h2 class="poster-title">Ưu Đãi Đặc Biệt</h2>
                        <p class="poster-desc">Tham gia cộng đồng BookStore để nhận voucher giảm giá lên đến 20%.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script>
    const togglePassword = document.querySelector('#togglePassword');
    const password = document.querySelector('#passwordInput');
    const icon = document.querySelector('#toggleIcon');
    
    togglePassword.addEventListener('click', function () {
        const type = password.getAttribute('type') === 'password' ? 'text' : 'password';
        password.setAttribute('type', type);
        icon.classList.toggle('bi-eye');
        icon.classList.toggle('bi-eye-slash');
    });
</script>
</body>
</html>