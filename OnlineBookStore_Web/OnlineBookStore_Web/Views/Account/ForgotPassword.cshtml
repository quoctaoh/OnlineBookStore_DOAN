@{
    ViewData["Title"] = "Quên Mật Khẩu";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-body">
                <h3 class="text-center mb-4 text-primary">Quên Mật Khẩu?</h3>
                <p class="text-muted text-center">Nhập email của bạn để nhận mã xác thực.</p>

                @if (ViewBag.Error != null)
                {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <form asp-action="ForgotPassword" method="post">
                    <div class="form-group mb-3">
                        <label class="control-label">Email đăng ký</label>
                        <input type="email" name="email" class="form-control" required placeholder="vidu@gmail.com" />
                    </div>

                    <div class="form-group d-grid">
                        <button type="submit" class="btn btn-primary">Gửi Mã Xác Thực</button>
                    </div>
                </form>

                <div class="text-center mt-3">
                    <a asp-action="Login">Quay lại Đăng nhập</a>
                </div>
            </div>
        </div>
    </div>
</div>