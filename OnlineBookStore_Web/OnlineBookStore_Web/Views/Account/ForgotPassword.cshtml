@{
    ViewData["Title"] = "Quên Mật Khẩu";
}

<style>
    :root {
        --navy-bg: #0a192f;
        --navy-darkest: #020c1b;
        --accent-cyan: #64ffda;
        --glass-white: rgba(255, 255, 255, 0.03);
        --glass-border: rgba(255, 255, 255, 0.1);
    }

    /* Hiệu ứng nền mờ cho Card */
    .forgot-glass-card {
        background: rgba(17, 34, 64, 0.7);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--glass-border);
        border-radius: 24px;
        padding: 40px;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
        margin-top: 50px;
    }

    .forgot-header i {
        font-size: 3.5rem;
        color: var(--accent-cyan);
        text-shadow: 0 0 20px rgba(100, 255, 218, 0.3);
    }

    .form-label-custom {
        font-size: 0.8rem;
        font-weight: 700;
        color: var(--accent-cyan);
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 8px;
        display: block;
    }

    .form-control-glass {
        background: rgba(2, 12, 27, 0.5) !important;
        border: 1px solid var(--glass-border) !important;
        color: white !important;
        border-radius: 12px !important;
        padding: 12px 15px !important;
        transition: 0.3s;
    }

        .form-control-glass:focus {
            border-color: var(--accent-cyan) !important;
            box-shadow: 0 0 15px rgba(100, 255, 218, 0.1) !important;
            outline: none;
        }

    .btn-cyan-glow {
        background: var(--accent-cyan) !important;
        color: var(--navy-darkest) !important;
        border: none !important;
        border-radius: 12px !important;
        padding: 14px !important;
        font-weight: 800 !important;
        text-transform: uppercase !important;
        letter-spacing: 1px !important;
        transition: 0.3s !important;
    }

        .btn-cyan-glow:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(100, 255, 218, 0.3);
            background: white !important;
        }

    .back-to-login {
        color: #8892b0;
        text-decoration: none;
        font-size: 0.9rem;
        transition: 0.3s;
    }

        .back-to-login:hover {
            color: var(--accent-cyan);
        }

    .alert-danger-glass {
        background: rgba(255, 77, 77, 0.1);
        border: 1px solid rgba(255, 77, 77, 0.2);
        color: #ff4d4d;
        border-radius: 12px;
        font-size: 0.9rem;
    }
</style>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="forgot-glass-card shadow-lg">
                <div class="forgot-header text-center mb-4">
                    <i class="bi bi-shield-lock"></i>
                    <h3 class="fw-bold text-white mt-3 mb-2">Quên Mật Khẩu?</h3>
                    <p class="text-muted small">Nhập email của bạn để nhận liên kết đặt lại mật khẩu.</p>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger-glass d-flex align-items-center mb-4" role="alert">
                        <i class="bi bi-exclamation-circle-fill me-2"></i>
                        <div>@ViewBag.Error</div>
                    </div>
                }

                <form asp-action="ForgotPassword" method="post">
                    <div class="mb-4">
                        <label class="form-label-custom">Email đăng ký</label>
                        <div class="position-relative">
                            <input type="email" name="email" class="form-control form-control-glass ps-5" required placeholder="vidu@gmail.com" />
                            <i class="bi bi-envelope position-absolute top-50 start-0 translate-middle-y ms-3 text-muted"></i>
                        </div>
                    </div>

                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-cyan-glow">
                            Gửi Liên Kết Xác Thực <i class="bi bi-send-fill ms-1"></i>
                        </button>
                    </div>
                </form>

                <div class="text-center mt-4 pt-3 border-top border-secondary border-opacity-25">
                    <a asp-action="Login" class="back-to-login">
                        <i class="bi bi-arrow-left me-1"></i> Quay lại Đăng nhập
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>