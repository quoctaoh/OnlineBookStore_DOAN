@{
    ViewData["Title"] = "Đặt Lại Mật Khẩu";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-body">
                <h3 class="text-center mb-4 text-success">Đặt Lại Mật Khẩu</h3>

                @if (ViewBag.Error != null)
                {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                }

                <form asp-action="ResetPassword" method="post">
                    @* Input ẩn để giữ email *@
                    <input type="hidden" name="email" value="@ViewBag.Email" />

                    <div class="form-group mb-3">
                        <label class="control-label">Mã OTP (kiểm tra email)</label>
                        <input type="text" name="otp" class="form-control" required placeholder="Nhập 6 số OTP" maxlength="6" />
                    </div>

                    <div class="form-group mb-3">
                        <label class="control-label">Mật khẩu mới</label>
                        <input type="password" name="newPassword" class="form-control" required />
                    </div>

                    <div class="form-group mb-3">
                        <label class="control-label">Xác nhận mật khẩu</label>
                        <input type="password" name="confirmPassword" class="form-control" required />
                    </div>

                    <div class="form-group d-grid">
                        <button type="submit" class="btn btn-success">Lưu Mật Khẩu Mới</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>