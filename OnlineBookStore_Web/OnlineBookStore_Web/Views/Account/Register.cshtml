@model OnlineBookStore_Web.Models.NguoiDung

@{
    ViewData["Title"] = "Đăng Ký Tài Khoản";
}

<h2>Đăng Ký Tài Khoản</h2>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Register">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            @* Trường Tên đăng nhập *@
            <div class="form-group">
                <label asp-for="TenDangNhap" class="control-label"></label>
                <input asp-for="TenDangNhap" class="form-control" />
                <span asp-validation-for="TenDangNhap" class="text-danger"></span>
            </div>

            @* Trường Họ tên *@
            <div class="form-group">
                <label asp-for="HoTen" class="control-label"></label>
                <input asp-for="HoTen" class="form-control" />
                <span asp-validation-for="HoTen" class="text-danger"></span>
            </div>

            @* Trường Email *@
            <div class="form-group">
                <label asp-for="Email" class="control-label"></label>
                <input asp-for="Email" class="form-control" type="email" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            @* Trường Mật khẩu *@
            <div class="form-group">
                <label asp-for="MatKhau" class="control-label"></label>
                <input asp-for="MatKhau" class="form-control" type="password" />
                <span asp-validation-for="MatKhau" class="text-danger"></span>
            </div>

            @* Trường Địa chỉ *@
            <div class="form-group">
                <label asp-for="DiaChi" class="control-label"></label>
                <input asp-for="DiaChi" class="form-control" />
                <span asp-validation-for="DiaChi" class="text-danger"></span>
            </div>

            <div class="form-group mt-3">
                <input type="submit" value="Đăng Ký" class="btn btn-success" />
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <p>Đã có tài khoản? <a asp-action="Login">Đăng nhập ngay</a></p>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}