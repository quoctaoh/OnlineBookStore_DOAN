@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OnlineBookStore</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <style>
        /* Biến màu chủ đạo - Navy Deep & Cyan */
        :root {
            --navy-bg: #0a192f;
            --navy-darkest: #020c1b;
            --navy-soft: #112240;
            --glass-white: rgba(255, 255, 255, 0.12);
            --glass-border: rgba(255, 255, 255, 0.2);
            --accent-cyan: #64ffda;
            --text-dim: #8892b0;
        }

        body {
            background-color: var(--navy-darkest) !important;
            color: #e6f1ff;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        /* --- NAVBAR STYLE (Fix nhảy hàng) --- */
        .modern-nav {
            background: var(--navy-bg);
            padding: 0.8rem 1rem;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }
        .navbar-brand {
            color: #ffffff !important;
            font-size: 1.6rem;
            font-weight: 800;
            text-decoration: none !important;
        }
        .navbar-brand i { color: var(--accent-cyan); }
        
        .btn-home {
            background-color: #ffffff !important;
            color: var(--navy-bg) !important;
            border-radius: 10px;
            font-weight: 700;
            padding: 0.6rem 1.2rem !important;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
            white-space: nowrap !important;
        }
        .btn-home:hover {
            background-color: var(--accent-cyan) !important;
            transform: translateY(-2px);
        }

        .nav-link {
            color: rgba(255, 255, 255, 0.8) !important;
            font-weight: 500;
            padding: 0.6rem 1rem !important;
            margin: 0 5px;
            border-radius: 10px;
            transition: 0.3s;
            white-space: nowrap !important; /* Ngăn nhảy hàng */
        }
        .nav-link:hover { color: var(--accent-cyan) !important; background: rgba(255,255,255,0.05); }

        .search-container {
            background: rgba(255, 255, 255, 0.07);
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            flex-grow: 1;
            max-width: 300px !important; /* Giảm độ rộng để tránh đẩy chữ */
        }
        .search-container input { color: white !important; }
        .search-btn {
            background: var(--accent-cyan);
            border: none;
            border-radius: 8px;
            width: 34px; height: 34px; margin: 4px;
            color: var(--navy-bg);
        }

        /* --- FOOTER STYLE --- */
        .footer-glass {
            background: rgba(10, 25, 47, 0.8);
            backdrop-filter: blur(15px);
            border-top: 1px solid rgba(255, 255, 255, 0.05);
            color: #ccd6f6;
        }
        .newsletter-section {
            background: rgba(100, 255, 218, 0.05);
            border-bottom: 1px solid rgba(100, 255, 218, 0.1);
        }
        .footer-heading {
            color: var(--accent-cyan);
            font-weight: 700;
            font-size: 0.9rem;
            margin-bottom: 20px;
            letter-spacing: 1px;
        }
        .footer-links { list-style: none; padding: 0; font-size: 0.85rem; }
        .footer-links li { margin-bottom: 12px; color: var(--text-dim); }
        .footer-links a { text-decoration: none; color: var(--text-dim); transition: 0.3s; }
        .footer-links a:hover { color: var(--accent-cyan); padding-left: 5px; }
        .form-control-footer {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid rgba(255, 255, 255, 0.1);
            color: white;
            border-radius: 8px;
            font-size: 0.85rem;
            padding: 10px 15px;
        }
        .btn-cyan-sm {
            background: var(--accent-cyan);
            color: #0a192f;
            border: none;
            font-weight: 700;
            font-size: 0.75rem;
            padding: 10px 15px;
            transition: 0.3s;
            border-radius: 8px;
        }
        .btn-cyan-sm:hover { background: white; transform: translateY(-2px); }

        /* --- CHATBOX STYLE --- */
        #chat-toggle-btn {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 60px;
            height: 60px;
            background: var(--accent-cyan);
            border: none;
            border-radius: 50%;
            color: var(--navy-darkest);
            font-size: 1.8rem;
            z-index: 9999;
            box-shadow: 0 10px 25px rgba(100, 255, 218, 0.3);
            transition: 0.3s;
        }
        .glass-chat-window {
            position: fixed;
            bottom: 100px;
            right: 30px;
            width: 350px;
            height: 500px;
            background: rgba(10, 25, 47, 0.9);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 20px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            animation: fadeInChat 0.3s ease;
        }
        .chat-header {
            padding: 15px 20px;
            background: rgba(100, 255, 218, 0.1);
            border-bottom: 1px solid var(--glass-border);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }
        #chat-content { flex: 1; padding: 20px; overflow-y: auto; display: flex; flex-direction: column; gap: 12px; }
        .msg { max-width: 80%; padding: 10px 15px; border-radius: 15px; font-size: 0.9rem; }
        .ai-msg { background: var(--navy-soft); color: #fff; align-self: flex-start; border: 1px solid var(--glass-border); }
        .user-msg { background: var(--accent-cyan); color: var(--navy-darkest); align-self: flex-end; font-weight: 600; }
        .chat-footer { padding: 15px; display: flex; gap: 10px; background: rgba(0,0,0,0.2); }
        .chat-footer input { flex: 1; background: rgba(255,255,255,0.05); border: 1px solid var(--glass-border); border-radius: 50px; padding: 8px 15px; color: #fff; outline: none; }
        .chat-footer button { background: none; border: none; color: var(--accent-cyan); font-size: 1.2rem; }

        @@keyframes fadeInChat { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    </style>
</head>
<body>
    <header class="sticky-top">
        <nav class="navbar navbar-expand-lg navbar-dark modern-nav">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-bookmarks-fill me-2"></i>BOOKSTORE
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="bi bi-grid-fill fs-2"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">
                    @{
                        var userId = Context.Session.GetInt32("UserId");
                        var userName = Context.Session.GetString("UserName");
                        var adminId = Context.Session.GetInt32("AdminId");
                        var adminName = Context.Session.GetString("AdminName");
                        var isAdmin = adminId.HasValue;
                        var cartCount = Context.Session.GetInt32("CartCount") ?? 0;
                        var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
                        var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
                    }

                    <ul class="navbar-nav me-auto align-items-center">
                        <li class="nav-item">
                            <a class="btn-home mx-lg-2" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>

                        @* NÚT QUẢN TRỊ: Luôn luôn hiển thị *@
                        <li class="nav-item">
                            @if (isAdmin)
                            {
                                <div class="dropdown">
                                    <a class="nav-link dropdown-toggle fw-bold text-warning" href="#" id="adminMenu" data-bs-toggle="dropdown">
                                        <i class="bi bi-shield-lock-fill me-1"></i> QUẢN TRỊ
                                    </a>
                                    <ul class="dropdown-menu dropdown-menu-dark shadow">
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="Index">Dashboard</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="ListBooks">Quản lý Sách</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="ListOrders">Quản lý Đơn hàng</a></li>
                                        <li><a class="dropdown-item" asp-controller="Admin" asp-action="SalesSummary">Báo cáo doanh thu</a></li>
                                    </ul>
                                </div>
                            }
                            else
                            {
                                <a class="nav-link fw-bold text-warning" asp-controller="Account" asp-action="LoginAdmin">
                                    <i class="bi bi-shield-lock-fill me-1"></i> QUẢN TRỊ
                                </a>
                            }
                        </li>

                        @if (!isAdmin)
                        {
                            <li class="nav-item">
                                <a class="nav-link @(currentController == "Book" ? "active-glass" : "")" asp-controller="Book" asp-action="Index">Danh mục</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link @(currentAction == "Privacy" ? "active-glass" : "")" asp-controller="Home" asp-action="Privacy">Chính sách</a>
                            </li>
                        }
                    </ul>

                    <form class="d-flex mx-lg-4 search-container" asp-controller="Book" asp-action="Index" method="get">
                        <input type="text" name="searchString" class="form-control border-0 bg-transparent px-3 shadow-none" placeholder="Tìm tên sách, tác giả...">
                        <button class="search-btn d-flex align-items-center justify-content-center" type="submit">
                            <i class="bi bi-search"></i>
                        </button>
                    </form>

                    <ul class="navbar-nav ms-auto align-items-center">
                        @if (isAdmin)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle fw-bold" href="#" data-bs-toggle="dropdown" style="color: var(--accent-cyan) !important;">
                                    <i class="bi bi-person-badge-fill me-1"></i> @adminName
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow">
                                    <li><a class="dropdown-item" asp-controller="Admin" asp-action="EditProfile">Sửa hồ sơ</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" asp-controller="Account" asp-action="LogoutAdmin">Đăng xuất Admin</a></li>
                                </ul>
                            </li>
                        }
                        else if (userId.HasValue)
                        {
                            <li class="nav-item me-3">
                                <a class="nav-link position-relative p-2" asp-controller="Cart" asp-action="Index">
                                    <i class="bi bi-bag-heart fs-4"></i>
                                    <span id="cart-count" class="position-absolute top-0 start-100 translate-middle badge rounded-pill">@cartCount</span>
                                </a>
                            </li>
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle fw-bold" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" style="color: var(--accent-cyan) !important;">
                                    <i class="bi bi-person-circle me-1"></i> @userName
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow">
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="OrderHistory">Lịch sử đơn hàng</a></li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-warning" asp-controller="Account" asp-action="Logout">Thoát</a></li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Đăng nhập</a></li>
                            <li class="nav-item ms-lg-2">
                                <a class="nav-link btn border-info text-info px-3" asp-controller="Account" asp-action="Register" style="border-radius: 10px;">Đăng ký</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-glass mt-5">
        <div class="newsletter-section p-4 mb-5">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-lg-5 text-center text-lg-start">
                        <h4 class="fw-bold mb-1" style="color: var(--accent-cyan);">Đăng ký nhận bản tin</h4>
                        <p class="text-muted small mb-0">Đừng bỏ lỡ những tin nhắn ưu đãi độc quyền dành riêng cho bạn</p>
                    </div>
                    <div class="col-lg-7 mt-3 mt-lg-0">
                        <div class="d-flex gap-2 flex-wrap flex-md-nowrap">
                            <input type="text" class="form-control-footer" placeholder="Nhập tên của bạn">
                            <input type="email" class="form-control-footer" id="newsletterEmail" placeholder="Nhập email của bạn">
                            <button type="button" id="btnNewsletter" class="btn-cyan-sm px-4">Đăng ký</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="container pb-5">
            <div class="row g-4 text-center text-md-start">
                <div class="col-md-3">
                    <h6 class="footer-heading">HỖ TRỢ KHÁCH HÀNG</h6>
                    <ul class="footer-links">
                        <li>Sản phẩm & Đơn hàng: 0982 442 047</li>
                        <li>Kỹ thuật & Bảo hành: 0982 442 047</li>
                        <li>Email: thanhnguyen10072k5@gmail.com</li>
                        <li>Địa chỉ: 233/46/6b NVC, P. Cái Khế, TP. Cần Thơ</li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h6 class="footer-heading">TRỢ GIÚP</h6>
                    <ul class="footer-links">
                        <li><a href="#">Hướng dẫn mua hàng</a></li>
                        <li><a href="#">Phương thức thanh toán</a></li>
                        <li><a href="#">Phương thức vận chuyển</a></li>
                        <li><a href="/Home/Privacy">Chính sách bảo mật</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h6 class="footer-heading">TÀI KHOẢN CỦA BẠN</h6>
                    <ul class="footer-links">
                        <li><a href="#">Cập nhật tài khoản</a></li>
                        <li><a href="/Cart">Giỏ hàng</a></li>
                        <li><a href="/Account/OrderHistory">Lịch sử giao dịch</a></li>
                        <li><a href="#">Sản phẩm yêu thích</a></li>
                    </ul>
                </div>
                <div class="col-md-3">
                    <h6 class="footer-heading">KẾT NỐI VỚI CHÚNG TÔI</h6>
                    <div class="social-icons mb-3">
                        <a href="#"><i class="bi bi-facebook"></i></a>
                        <a href="#"><i class="bi bi-instagram"></i></a>
                        <a href="#"><i class="bi bi-tiktok"></i></a>
                        <a href="#"><i class="bi bi-youtube"></i></a>
                    </div>
                    
                </div>
            </div>
        </div>

        <div class="footer-bottom py-4 text-center">
            <div class="container">
                <div class="row align-items-center">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <span class="small me-3 text-dim">CHẤP NHẬN THANH TOÁN:</span>
                        <img src="~/payOSlogo.png" width="30" class="me-2 rounded shadow-sm">
                        <i class="bi bi-credit-card fs-4 me-2"></i>
                        <i class="bi bi-cash-stack fs-4"></i>
                    </div>
                    <div class="col-md-6">
                        <span class="small me-3 text-dim">CÓ MẶT TRÊN:</span>
                        <img src="https://upload.wikimedia.org/wikipedia/commons/thumb/f/fe/Shopee.svg/1200px-Shopee.svg.png" width="60" class="me-3 opacity-75">
                        
                    </div>
                </div>
            </div>
        </div>
    </footer>

    <button id="chat-toggle-btn" title="Hỗ trợ AI">
        <i class="bi bi-robot"></i>
    </button>

    <div id="chat-window" class="glass-chat-window d-none">
        <div class="chat-header">
            <div class="d-flex align-items-center">
                <i class="bi bi-cpu text-info me-2 fs-4"></i>
                <span class="fw-bold">BookStore AI Assistant</span>
            </div>
            <button id="close-chat" class="btn-close btn-close-white shadow-none" style="font-size: 0.8rem;"></button>
        </div>
        <div id="chat-content">
            <div class="msg ai-msg shadow-sm">Bookstore xin chào! Bạn cần hỗ trợ hãy để lại lời nhắn.</div>
        </div>
        <div class="chat-footer">
            <input type="text" id="chat-input" placeholder="Nhập câu hỏi..." autocomplete="off">
            <button id="chat-send"><i class="bi bi-send-fill"></i></button>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        $(document).ready(function() {
            // Logic Chat AI
            const $chatWindow = $('#chat-window');
            const $chatInput = $('#chat-input');
            const $chatContent = $('#chat-content');

            $('#chat-toggle-btn').on('click', () => {
                $chatWindow.toggleClass('d-none');
                $chatInput.focus();
            });

            $('#close-chat').on('click', () => $chatWindow.addClass('d-none'));

            function appendMsg(text, type) {
                const msgClass = type === 'user' ? 'user-msg' : 'ai-msg';
                $chatContent.append(`<div class="msg ${msgClass} shadow-sm">${text}</div>`);
                $chatContent.scrollTop($chatContent[0].scrollHeight);
            }

            $('#chat-send').on('click', function() {
                const val = $chatInput.val().trim();
                if(val) {
                    appendMsg(val, 'user');
                    $chatInput.val('');
                    setTimeout(() => appendMsg("Cảm ơn bạn, tôi sẽ phản hồi sớm nhất!", 'ai'), 800);
                }
            });

            $chatInput.on('keypress', (e) => { if(e.which == 13) $('#chat-send').click(); });

            // LOGIC RELOAD KHI ĐĂNG KÝ BẢN TIN
            $('#btnNewsletter').on('click', function() {
                const email = $('#newsletterEmail').val();
                if(email) {
                    alert("Cảm ơn bạn đã đăng ký nhận bản tin!");
                    location.reload(); // Reload lại trang
                } else {
                    alert("Vui lòng nhập Email để đăng ký!");
                }
            });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
    <script>
    function notifySuccess(message) {
    Swal.fire({
        icon: 'success',
        title: 'Thành công!',
        text: message,
        position: 'center',      // <--- Bắt buộc là center
        toast: false,            // <--- Phải để false để nó hiện thành bảng giữa màn hình
        showConfirmButton: false,
        timer: 2000,
        background: '#112240',   // Màu nền Navy của bạn
        color: '#64ffda',        // Màu chữ Cyan
        iconColor: '#64ffda',
        backdrop: `rgba(2, 12, 27, 0.7)` // Làm mờ nền xung quanh
    });
}
}
    }
</script>
</body>
</html>