@using Microsoft.AspNetCore.Http
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - OnlineBookStore</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" />
    
    <style>
        /* Biến màu chủ đạo */
        :root {
            --navy-bg: #0a192f;
            --glass-white: rgba(255, 255, 255, 0.12);
            --glass-border: rgba(255, 255, 255, 0.2);
            --accent-cyan: #64ffda;
        }

        body {
            background-color: #f4f7f6; /* Nền trang nhẹ nhàng để nổi bật Navbar */
        }

        /* Navbar Navy Sang Trọng */
        .modern-nav {
            background: var(--navy-bg);
            padding: 0.8rem 1rem;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        }

        .navbar-brand {
            color: #ffffff !important;
            font-size: 1.6rem;
            font-weight: 800;
            letter-spacing: -0.5px;
        }
        .navbar-brand i { color: var(--accent-cyan); }

        /* Nút Trang Chủ Đặc Biệt */
        .btn-home {
            background-color: #ffffff !important;
            color: var(--navy-bg) !important;
            border-radius: 10px;
            font-weight: 700;
            padding: 0.6rem 1.5rem !important;
            transition: all 0.3s ease;
            text-decoration: none;
            display: inline-block;
            box-shadow: 0 4px 15px rgba(255, 255, 255, 0.1);
        }
        .btn-home:hover {
            background-color: var(--accent-cyan) !important;
            transform: translateY(-2px);
        }

        /* Hiệu ứng Kính (Glassmorphism) cho các Nav-link */
        .nav-link {
            color: rgba(255, 255, 255, 0.8) !important;
            font-weight: 500;
            padding: 0.6rem 1.2rem !important;
            margin: 0 5px;
            border-radius: 10px;
            border: 1px solid transparent;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Khi di chuột qua: Hiệu ứng kính nhẹ */
        .nav-link:hover {
            background: rgba(255, 255, 255, 0.05);
            color: var(--accent-cyan) !important;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        /* KHI ẤN VÀO (ACTIVE): Hiệu ứng kính bao bọc rõ rệt */
        .nav-link.active-glass {
            background: var(--glass-white) !important;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border: 1px solid var(--glass-border) !important;
            color: #ffffff !important;
            box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.2);
        }

        /* Thanh tìm kiếm Glassmorphism */
        .search-container {
            background: rgba(255, 255, 255, 0.07);
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: 0.3s;
        }
        .search-container:focus-within {
            background: rgba(255, 255, 255, 0.12);
            border-color: var(--accent-cyan);
        }
        .search-container input { color: white !important; }
        .search-container input::placeholder { color: rgba(255,255,255,0.4); }

        .search-btn {
            background: var(--accent-cyan);
            border: none;
            border-radius: 8px;
            width: 34px;
            height: 34px;
            margin: 4px;
            color: var(--navy-bg);
        }

        /* Cart Badge */
        #cart-count {
            background-color: var(--accent-cyan) !important;
            color: var(--navy-bg);
            font-weight: bold;
        }

        /* Dropdown sang trọng */
        .dropdown-menu {
            background: #112240;
            border: 1px solid var(--glass-border);
            border-radius: 12px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.4);
            padding: 0.5rem;
        }
        .dropdown-item {
            color: rgba(255,255,255,0.8);
            border-radius: 8px;
            padding: 0.6rem 1rem;
        }
        .dropdown-item:hover {
            background: var(--glass-white);
            color: var(--accent-cyan);
        }
    </style>
</head>
<body>
    <header class="sticky-top">
        <nav class="navbar navbar-expand-lg navbar-dark modern-nav">
            <div class="container">
                <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-bookmarks-fill me-2"></i>BOOKSTORE
                </a>

                <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                    <span class="bi bi-grid-fill fs-2"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarMain">
                    @{
                        var userId = Context.Session.GetInt32("UserId");
                        var userName = Context.Session.GetString("UserName");
                        var adminName = Context.Session.GetString("AdminName");
                        var isAdmin = !string.IsNullOrEmpty(adminName);
                        var cartCount = Context.Session.GetInt32("CartCount") ?? 0;
                        
                        // Lấy thông tin Controller/Action hiện tại để set class Active
                        var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
                        var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
                    }

                    <ul class="navbar-nav me-auto align-items-center">
                        <li class="nav-item">
                            <a class="btn-home mx-lg-2" asp-controller="Home" asp-action="Index">Trang chủ</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentController == "Book" ? "active-glass" : "")" 
                               asp-controller="Book" asp-action="Index">Danh mục</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link @(currentAction == "Privacy" ? "active-glass" : "")" 
                               asp-controller="Home" asp-action="Privacy">Chính sách</a>
                        </li>
                    </ul>

                    <form class="d-flex mx-lg-4 search-container" asp-controller="Book" asp-action="Index" method="get" style="flex-grow: 1; max-width: 380px;">
                        <input type="text" name="searchString" class="form-control border-0 bg-transparent px-3 shadow-none" placeholder="Tìm tên sách, tác giả...">
                        <button class="search-btn d-flex align-items-center justify-content-center" type="submit">
                            <i class="bi bi-search"></i>
                        </button>
                    </form>

                    <ul class="navbar-nav ms-auto align-items-center">
                        <li class="nav-item me-3">
                            <a class="nav-link position-relative p-2 @(currentController == "Cart" ? "active-glass" : "")" 
                               asp-controller="Cart" asp-action="Index">
                                <i class="bi bi-bag-heart fs-4"></i>
                                <span id="cart-count" class="position-absolute top-0 start-100 translate-middle badge rounded-pill">
                                    @cartCount
                                </span>
                            </a>
                        </li>

                        @if (userId.HasValue) {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle fw-bold" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false" style="color: var(--accent-cyan) !important;">
                                    <i class="bi bi-person-circle me-1"></i> @userName
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="userDropdown">
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="OrderHistory"><i class="bi bi-clock-history me-2"></i>Đơn hàng</a></li>
                                    <li><hr class="dropdown-divider border-secondary"></li>
                                    <li><a class="dropdown-item text-warning" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i>Thoát</a></li>
                                </ul>
                            </li>
                        } else if (isAdmin) {
                            <li class="nav-item"><a class="nav-link text-warning fw-bold" asp-controller="Admin" asp-action="Index"><i class="bi bi-person-badge me-1"></i>QUẢN TRỊ</a></li>
                            <li class="nav-item"><a class="nav-link small" asp-controller="Account" asp-action="LogoutAdmin">Thoát</a></li>
                        } else {
                            <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Đăng nhập</a></li>
                            <li class="nav-item ms-lg-2">
                                <a class="nav-link btn border-info text-info px-3" asp-controller="Account" asp-action="Register" style="border-radius: 10px;">Đăng ký</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container mt-4">
        <main role="main" class="pb-5">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>