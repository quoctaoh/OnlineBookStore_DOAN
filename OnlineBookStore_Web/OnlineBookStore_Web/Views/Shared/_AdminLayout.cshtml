@using Microsoft.AspNetCore.Http
@inject IHttpContextAccessor HttpContextAccessor
@{
    var adminName = HttpContextAccessor.HttpContext.Session.GetString("AdminName");
    ViewData["Title"] = ViewData["Title"]; 
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Dashboard</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" /> 

    <style>
        .admin-wrapper {
            display: flex;
            min-height: 100vh;
        }
        .sidebar {
            width: 250px;
            background-color: #343a40;
            padding-top: 20px;
            position: sticky; 
            top: 0;
            overflow-y: auto;
        }
        .sidebar .nav-link {
            color: #ccc;
            padding: 10px 15px;
        }
        .sidebar .nav-link:hover {
            color: #fff;
            background-color: #495057;
        }
        .sidebar-heading {
            font-size: 0.75rem;
            text-transform: uppercase;
            font-weight: bold;
        }
        .content-wrapper {
            flex-grow: 1;
            padding: 20px;
        }
    </style>
</head>
<body>

    <header class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark border-bottom box-shadow">
        <div class="container-fluid">
            <a class="navbar-brand text-warning fw-bold" asp-controller="Admin" asp-action="Index">ADMIN PANEL</a>

            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end">
                <ul class="navbar-nav">

                    <li class="nav-item me-3">
                        <a class="nav-link text-white" asp-controller="Home" asp-action="Index">
                             <i class="fas fa-home me-1"></i> Trang Chủ Công Khai
                        </a>
                    </li>

                    @* ADMIN PROFILE DROPDOWN  *@
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle text-warning" href="#" id="adminDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Xin chào, <strong>@adminName</strong>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="adminDropdown">
                            <li>
                                <a class="dropdown-item" asp-controller="Admin" asp-action="EditProfile">
                                    <i class="fas fa-user-edit me-2"></i> Cập nhật Thông tin
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item text-danger" asp-controller="Account" asp-action="LogoutAdmin">
                                    <i class="fas fa-sign-out-alt me-2"></i> Đăng xuất
                                </a>
                            </li>
                        </ul>
                    </li>
                </ul>
            </div>
        </div>
    </header>

    <div class="admin-wrapper">

        <nav class="sidebar">
            <div class="nav flex-column">
                <a class="nav-link active" asp-controller="Admin" asp-action="Index">
                    <i class="fas fa-tachometer-alt me-2"></i> Dashboard
                </a>

                <h6 class="sidebar-heading px-3 mt-4 mb-1 text-muted">TÀI KHOẢN CÁ NHÂN</h6>
                <a class="nav-link" asp-controller="Admin" asp-action="EditProfile">
                    <i class="fas fa-user-edit me-2"></i> Cập nhật Thông tin
                </a>

                <h6 class="sidebar-heading px-3 mt-4 mb-1 text-muted">QUẢN LÝ SẢN PHẨM</h6>
                <a class="nav-link" asp-controller="Admin" asp-action="ListBooks"><i class="fas fa-book me-2"></i> Danh sách Sách</a>
                <a class="nav-link" asp-controller="Admin" asp-action="CreateBook"><i class="fas fa-plus-circle me-2"></i> Thêm Sách mới</a>

                <h6 class="sidebar-heading px-3 mt-4 mb-1 text-muted">GIAO DỊCH & BÁO CÁO</h6>
                <a class="nav-link" asp-controller="Admin" asp-action="ListOrders"><i class="fas fa-box me-2"></i> Quản lý Đơn hàng</a>
                <a class="nav-link" asp-controller="Admin" asp-action="SalesSummary"><i class="fas fa-chart-bar me-2"></i> Báo cáo Doanh thu</a>
            </div>
        </nav>

        <main role="main" class="content-wrapper">
            @if (TempData["SuccessMessage"] != null)
            {
                    <div class="alert alert-success alert-dismissible fade show" role="alert">
                        <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
            }
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script> 

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>